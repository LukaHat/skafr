{
  "name": "skafr",
  "version": "0.1.0",
  "description": "Opinionated scaffolding tool for Express and React Typescript projects",
  "license": "MIT",
  "author": "Luka Hat",
  "keywords": [
    "cli",
    "scaffold",
    "express",
    "typescript",
    "generator",
    "boilerplate"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LukaHat/skafr.git"
  },
  "homepage": "https://github.com/LukaHat/skafr#readme",
  "scripts": {
    "test:dev": "npm run build && node dist/index.js init test-project",
    "test:clean": "rm -rf test-project",
    "test:run": "npm run test:clean; npm run test:dev",
    "build": "rm -rf dist && tsc && cp -r templates dist/"
  },
  "bin": {
    "skafr": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "inquirer": "^13.4.2",
    "pluralize": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/pluralize": "^0.0.33",
    "typescript": "^6.0.2"
  }
}
